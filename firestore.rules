rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
        allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(gameId) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(gameId) && incoming().ownerId == existing().ownerId;
    }

    match /games/{gameId}/matches/{matchId} {
      // Allow any signed in to read
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(gameId) && isValidId(matchId) &&
        request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerIds;
      allow update: if isSignedIn() && isValidId(gameId) && isValidId(matchId) &&
        request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerIds;
    }
  }
}
